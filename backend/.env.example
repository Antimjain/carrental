# Copy to .env for local development. All values are optional.

# Port the API listens on (the host sets this in production).
# PORT=3001

# Restrict which frontend origin may call the API. Unset allows any origin.
# CORS_ORIGIN=http://localhost:3000

# Storage adapter: leave unset for in-memory, or "postgres" for a database.
# DB_DRIVER=postgres

# Connection string used when DB_DRIVER=postgres.
# DATABASE_URL=postgres://postgres:dev@localhost:5432/carental
